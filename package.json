{
	"name": "@bmd/featured-image-block-fallback",
	"version": "0.1.2",
	"description": "Block editor plugin to add a fallback image for the featured image block",
	"author": "Bob Moore <bob@bobmoore.dev>",
	"license": "GPL-2.0-or-later",
	"keywords": [
		"plugin",
		"wordpress",
		"block",
		"block-editor",
		"block-editor-plugin",
		"featured-image",
		"gutenberg"
	],
	"homepage": "https://www.bobmoore.dev",
	"repository": "https://github.com/bob-moore/Featured-Image-Block-Fallback",
	"bugs": "https://github.com/bob-moore/Featured-Image-Block-Fallback/issues",
	"files": [
		"plugin.php",
		"build",
		"assets",
		"inc",
		"vendor",
		"readme.txt"
	],
	"devDependencies": {
		"@wordpress/block-editor": "^14.16.0",
		"@wordpress/components": "^32.6.0",
		"@wordpress/compose": "^7.44.0",
		"@wordpress/hooks": "^4.44.0",
		"@wordpress/scripts": "^30.14.0",
		"sass": "^1.85.0",
		"@types/react": "^18.3.28"
	},
	"scripts": {
		"build": "npm run fix:js && npm run compile",
		"compile": "wp-scripts build",
		"watch": "wp-scripts start",
		"watch:hot": "wp-scripts start --hot",
		"check-engines": "wp-scripts check-engines",
		"check-licenses": "wp-scripts check-licenses --prod --gpl2",
		"format": "wp-scripts format",
		"lint:css": "wp-scripts lint-style './src/**/*.scss'",
		"fix:css": "wp-scripts lint-style './src/**/*.scss' --fix",
		"lint:js": "wp-scripts lint-js",
		"fix:js": "wp-scripts lint-js --fix",
		"lint:md:docs": "wp-scripts lint-md-docs",
		"lint:pkg-json": "wp-scripts lint-pkg-json",
		"packages-update": "wp-scripts packages-update",
		"zip": "wp-scripts plugin-zip --root-folder='featured-image-block-fallback'"
	},
	"browserslist": [
		"last 3 version",
		"> 1%",
		"not dead"
	]
}