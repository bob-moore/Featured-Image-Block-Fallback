{
	"$schema": "https://playground.wordpress.net/blueprint-schema.json",
	"landingPage": "/featured-image-fallback-demo/",
	"login": true,
	"features": {
		"networking": true
	},
	"steps": [
		{
			"step": "updateUserMeta",
			"meta": {
				"admin_color": "modern",
				"show_welcome_panel": 0
			},
			"userId": 1
		},
		{
			"step": "setSiteOptions",
			"options": {
				"blogname": "Featured Image Block Fallback",
				"permalink_structure": "/%postname%/"
			}
		},
		{
			"step": "installPlugin",
			"pluginZipFile": {
				"resource": "url",
				"url": "https://github.com/bob-moore/Featured-Image-Block-Fallback/releases/latest/download/featured-image-block-fallback.zip"
			}
		},
		{
			"step": "installTheme",
			"themeZipFile": {
				"resource": "wordpress.org/themes",
				"slug": "twentytwentyfour"
			}
		},
		{
			"step": "importWxr",
			"file": {
				"resource": "url",
				"url": "https://raw.githubusercontent.com/bob-moore/Featured-Image-Block-Fallback/main/_playground/demo-content.xml"
			}
		}
	]
}
