{
    "name": "bmd/featured-image-block-fallback",
    "description": "Provide a fallback image for the featured image block",
    "type": "library",
    "authors": [
        {
            "name": "Bob Moore",
            "email": "bob@bobmoore.dev"
        }
    ],
    "homepage": "https://github.com/bob-moore/Featured-Image-Block-Fallback",
    "license": "GPL-2.0-or-later",
    "minimum-stability": "dev",
    "prefer-stable": true,
    "config": {
        "optimize-autoloader": true,
        "vendor-dir": "vendor",
        "platform": {
            "php": "8.2"
        },
        "allow-plugins": {
            "composer/installers": true,
            "dealerdirect/phpcodesniffer-composer-installer": true,
            "phpstan/extension-installer": true,
            "wpify/scoper": true
        }
    },
    "autoload": {
        "psr-4": {
            "Bmd\\FeaturedImageBlockFallback\\": "./inc"
        }
    },
    "require": {
        "php-di/php-di": "^7.1"
    },
    "autoload-dev": {
        "psr-4": {
            "Bmd\\FeaturedImageBlockFallback\\Tests\\": "./tests"
        }
    },
    "require-dev": {
        "bmd/github-wp-updater": "^0.1.2",
        "squizlabs/php_codesniffer": "^3.7",
        "phpunit/phpunit": "^9.6",
        "10up/wp_mock": "^1.0",
        "symfony/var-dumper": "*",
        "wp-coding-standards/wpcs": "^3.0",
        "phpstan/phpstan": "^1.10",
        "szepeviktor/phpstan-wordpress": "^1.3",
        "phpcsstandards/phpcsutils": "^1.0",
        "wpify/scoper": "^3.2"
    },
    "scripts": {
        "build-release": "node scripts/build-plugin-release.mjs",
        "build-release:docker": "scripts/build-plugin-release-docker.sh",
        "phpstan": "./vendor/bin/phpstan analyze -c ./phpstan.neon --memory-limit=2048M",
        "phpsniff": "./vendor/bin/phpcs ./inc -v --standard='./phpcs.xml'",
        "phpsniff:fix": "./vendor/bin/phpcbf ./inc -v --standard='./phpcs.xml'",
        "phpsniff:default": "./vendor/bin/phpcs ./inc -v",
        "phpsniff:PSR12": "./vendor/bin/phpcs ./inc -v --standard='PSR12'",
        "phpsniff:PSR2": "./vendor/bin/phpcs ./inc -v --standard='PSR2'",
        "phpsniff:WP": "./vendor/bin/phpcs ./inc -v --standard='WordPress'",
        "wpify:install": "wpify-scoper install",
        "wpify:update": "wpify-scoper update",
        "wpify-scoper": "wpify-scoper",
        "phpunit": "./vendor/bin/phpunit",
        "test": [
            "@phpstan",
            "@phpsniff",
            "@phpunit"
        ]
    },
    "extra": {
        "plugin-release": {
            "files": [
                "assets",
                "build",
                "inc",
                "README.md",
                "readme.md",
                "readme.txt",
                "LICENSE",
                "license.txt",
                "featured-image-block-fallback.php"
            ],
            "exclude": [
                "*.map",
                "*.psd"
            ]
        },
        "wpify-scoper": {
            "prefix": "Bmd\\FeaturedImageBlockFallback",
            "slug": "featured-image-block-fallback",
            "folder": "./vendor/scoped",
            "composerjson": "composer-deps.json",
            "composerlock": "composer-deps.lock",
            "autorun": false,
            "source-namespace-patches": [
                "DI\\",
                "Bmd\\GithubWpUpdater"
            ]
        }
    }
}
